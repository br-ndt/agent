# ── LLM Providers ───────────────────────────────────────────
#
# Claude uses your Pro/Max subscription via the CLI (no API key needed).
# Just run: npm install -g @anthropic-ai/claude-code && claude login
#
# API keys below are only needed for NON-Claude models.
# Leave blank/commented to skip that provider.

# Anthropic API — only if you want to ALSO use the per-token API
# (useful if you hit subscription rate limits)
# ANTHROPIC_API_KEY=sk-ant-...

# For GPT-4o researcher subagent
# OPENAI_API_KEY=sk-...

# For Gemini Flash (very cheap fast helper)
# GOOGLE_API_KEY=AIza...

# ── Chat Platform Tokens ────────────────────────────────────
# Get from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC...

# Get from Discord Developer Portal
# DISCORD_BOT_TOKEN=MTIz...

# ── Access Control ──────────────────────────────────────────
# Your Telegram user ID (send /start to @userinfobot to find it)
# ADMIN_TELEGRAM_ID=123456789

# ── Agent Git Identity ──────────────────────────────────────
# Used for all git commits made by subagents.
# Falls back to system git config if unset.
# GIT_AGENT_NAME=my-agent
# GIT_AGENT_EMAIL=my-agent@users.noreply.github.com
# GIT_SSH_COMMAND=ssh -i ~/.ssh/id_my_bot -o StrictHostKeyChecking=no

# ── Optional ────────────────────────────────────────────────
# LOG_LEVEL=INFO
# STATUS_PORT=8765
